  graph [rankdir=TB, bgcolor="white", margin=0.2, nodesep=0.45, ranksep=0.65];
  node [shape=rect, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, fillcolor="#F8FAFC", color="#CBD5E1"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#475569"];
  p [label="ClearingSettlementPolicy
策略主表
policy_no / scope / priority"];
  v [label="PolicyVersion
账期、结算模式、发起方式
