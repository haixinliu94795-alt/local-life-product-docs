  pos [label="SettlementPosition
结算头寸"];
  bill [label="SettlementBill
结算单"];
  p -> v [label="1:N 版本"];
  v -> r [label="1:N 规则"];
  r -> pr [label="1:N 参与方"];
  b -> p [label="引用策略"];
  v -> s [label="发布后形成快照"];
  s -> cr [label="清分命中"];
  s -> pos [label="头寸继承策略口径"];
