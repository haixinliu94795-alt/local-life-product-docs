
digraph G {
  graph [rankdir=LR, bgcolor="white", pad="0.2", nodesep="0.5", ranksep="0.6"];
  node [shape=ellipse, style="filled", fontname="Noto Sans CJK SC", fontsize=11, color="#334155", fillcolor="#F8FAFC"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#475569"];
  INIT [label="INIT
已创建"];
  CLEARING [label="CLEARING
清分中"];
  CLEARED [label="CLEARED
清分完成"];
  PENDING [label="PENDING
待结算"];
  MATURED [label="MATURED
账期成熟"];
  LOCKED [label="LOCKED
已锁定批次"];
  CONFIRMED [label="CONFIRMED
已确认"];
  PROCESSING [label="ACCOUNTING_PROCESSING
入账中"];
  SUCCESS [label="ACCOUNTING_SUCCESS
已结算入账", fillcolor="#DCFCE7"];
  FAILED [label="FAILED
失败", fillcolor="#FEE2E2"];
  UNKNOWN [label="UNKNOWN
未知", fillcolor="#FEF3C7"];
  CANCELED [label="CANCELED
取消", fillcolor="#E5E7EB"];
  INIT -> CLEARING -> CLEARED -> PENDING -> MATURED -> LOCKED -> CONFIRMED -> PROCESSING -> SUCCESS;
  CLEARING -> FAILED;
  PROCESSING -> FAILED;
  PROCESSING -> UNKNOWN;
  FAILED -> PROCESSING [label="重试"];
  UNKNOWN -> SUCCESS [label="核查成功"];
  UNKNOWN -> FAILED [label="核查失败"];
  PENDING -> CANCELED;
  LOCKED -> CANCELED;
}
