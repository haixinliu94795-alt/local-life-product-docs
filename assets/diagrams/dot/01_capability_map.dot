
digraph G {
  graph [rankdir=LR, bgcolor="white", pad="0.3", nodesep="0.6", ranksep="0.75"];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#334155", fillcolor="#F8FAFC"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#475569"];
  subgraph cluster_cs {
    label="清结算平台 Clear-Settlement Platform"; fontname="Noto Sans CJK SC"; fontsize=17; color="#3B82F6"; style="rounded";
    intake [label="业务接入
标准事件/订单快照"];
    rule [label="规则中心
账期/费率/成本分摊"];
    split [label="清分中心
单笔金额拆分"];
    clearing [label="清算中心
账期成熟/汇总/轧差"];
    pool [label="待结算池
冻结/锁定/可结算"];
    bill [label="结算中心
批次/结算单/明细"];
    acct [label="账务编排
入账/幂等/重试"];
    recon [label="对账差错
订单-清分-清算-结算-账务"];
    query [label="查询投影
后台/商户端"];
  }
  order [label="订单/履约/核销/退款", fillcolor="#FEF3C7"];
  pay [label="支付平台/渠道账单", fillcolor="#FEF3C7"];
  account [label="账户账务平台
余额与流水事实", fillcolor="#DCFCE7"];
  payout [label="提现/出款平台", fillcolor="#DCFCE7"];
  admin [label="后台运营平台", fillcolor="#F3E8FF"];
  merchant [label="商户端/BFF", fillcolor="#F3E8FF"];
  order -> intake -> split -> clearing -> pool -> bill -> acct -> account;
  rule -> split;
  rule -> clearing;
  pay -> recon;
  split -> recon;
  clearing -> recon;
  bill -> recon;
  acct -> recon;
  payout -> recon;
  admin -> pool [label="查询/冻结/解冻"];
  admin -> bill [label="生成/确认/重试"];
  bill -> query; pool -> query; account -> query;
  merchant -> query;
  merchant -> payout [label="提现申请"];
}
