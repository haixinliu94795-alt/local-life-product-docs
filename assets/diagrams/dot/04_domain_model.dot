
digraph G {
  graph [rankdir=LR, bgcolor="white", pad="0.25", nodesep="0.45", ranksep="0.55"];
  node [shape=record, fontname="Noto Sans CJK SC", fontsize=10, color="#334155", fillcolor="#FAFAFA", style="filled"];
  event [label="{SourceEvent|event_no
business_scene
event_type
biz_order_no
idempotent_key}"];
  order [label="{SourceOrderSnapshot|order_no
merchant_id
paid_amount
writeoff_time
refund_status}"];
  rule [label="{RuleSnapshot|rule_snapshot_no
cycle_days
share_ratio
cost_split_rule}"];
  split [label="{ClearingResult|clearing_no
source_order_no
gross_amount
merchant_amount
platform_amount}"];
  splitItem [label="{ClearingResultItem|participant_type
participant_id
amount_type
amount
cost_owner}"];
  clearBatch [label="{ClearingBatch|clearing_batch_no
period_start/end
merchant_id
net_amount
status}"];
  pending [label="{PendingSettlementItem|pending_item_no
due_time
status
freeze_reason
lock_batch_no}"];
  batch [label="{SettlementBatch|batch_no
scene
merchant_id
status}"];
  bill [label="{SettlementBill|bill_no
merchant_id
payable_amount
status
idempotent_key}"];
  billItem [label="{SettlementBillItem|bill_item_no
pending_item_no
source_order_no
amount}"];
  acc [label="{AccountingOrder|accounting_order_no
bill_no
accounting_request_no
status
retry_count}"];
  event -> order -> rule -> split -> splitItem;
  split -> clearBatch -> pending -> batch -> bill -> billItem;
  bill -> acc;
}
