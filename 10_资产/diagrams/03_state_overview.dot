
digraph G {
  graph [rankdir=LR, bgcolor="white", fontname="Noto Sans CJK SC"];
  node [shape=ellipse, style="filled", fillcolor="#F7F8FA", color="#4B5563", fontname="Noto Sans CJK SC", fontsize=11];
  edge [color="#4B5563", fontname="Noto Sans CJK SC", fontsize=9];
  IN_TRANSIT -> ELIGIBLE [label="账期成熟"];
  ELIGIBLE -> LOCKED [label="确认结算锁定"];
  LOCKED -> ACCOUNTING_PROCESSING [label="开始入账"];
  ACCOUNTING_PROCESSING -> ACCOUNTED [label="账务成功"];
  ACCOUNTING_PROCESSING -> ACCOUNTING_FAILED [label="账务失败"];
  ACCOUNTING_FAILED -> ACCOUNTING_PROCESSING [label="重试"];
  IN_TRANSIT -> CANCELED [label="结算前全额退款"];
  ELIGIBLE -> CANCELED [label="结算前全额退款"];
}
